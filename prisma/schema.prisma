generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────

enum Role {
  ADMIN
  FACTURACION
  IGUALADOR
  VENDEDOR_READONLY
}

enum OrderStatus {
  PENDIENTE
  EN_PROCESO
  LISTO
  ENTREGADO
  CANCELADO
  PAUSADO
}

enum OrderSource {
  MOSTRADOR
  VENTAS
  WHATSAPP
  REDES_SOCIALES
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGED
  QUEUE_REORDERED
  ORDER_EDITED
  ORDER_PAUSED
  ORDER_QUEUE_MOVED
  LOGIN
  EMAIL_SENT
  WHATSAPP_SENT
  LABEL_PRINTED
}

// ─── Models ─────────────────────────────────────────────

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  orders    Order[]
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  hashedPassword String
  role           Role     @default(VENDEDOR_READONLY)
  active         Boolean  @default(true)
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sellerOrders    Order[]  @relation("SellerOrders")
  igualadorOrders Order[]  @relation("IgualadorOrders")
  ayudanteOrders  Order[]  @relation("AyudanteOrders")
  auditLogs       AuditLog[]
}

model Client {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  company     String?
  notes       String?
  allowCredit Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model ColorGroup {
  id          String      @id @default(cuid())
  name        String
  description String?
  active      Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orders      Order[]
}

model IgualacionLine {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model FolioSequence {
  id        String @id // format: "YYMMDD"
  lastValue Int    @default(0)
}

/// 🆕 Tabla independiente para los operadores físicos del taller
/// (personas reales, distinto de la cuenta de sistema compartida).
model Igualador {
  id        String   @id @default(cuid())
  nombre    String
  activo    Boolean  @default(true)
  creadoAt  DateTime @default(now())
  actualizadoAt DateTime @updatedAt
  orders           Order[]  @relation("OperadorFisicoOrders")
  ayudanteOrders   Order[]  @relation("AyudanteFisicoOrders")
}

/// 🆕 Tabla independiente para los vendedores físicos
/// (personas reales del equipo de ventas, sin cuentas de sistema).
model Vendedor {
  id        String   @id @default(cuid())
  nombre    String
  activo    Boolean  @default(true)
  creadoAt  DateTime @default(now())
  actualizadoAt DateTime @updatedAt
  orders    Order[]  @relation("VendedorFisicoOrders")
}

model Order {
  id                    String          @id @default(cuid())
  folio                 String          @unique
  clientId              String
  client                Client          @relation(fields: [clientId], references: [id])
  sellerId              String
  seller                User            @relation("SellerOrders", fields: [sellerId], references: [id])
  igualadorId           String?
  igualador             User?           @relation("IgualadorOrders", fields: [igualadorId], references: [id])
  ayudanteId            String?
  ayudante              User?           @relation("AyudanteOrders", fields: [ayudanteId], references: [id])
  operadorFisicoId      String?
  operadorFisico        Igualador?      @relation("OperadorFisicoOrders", fields: [operadorFisicoId], references: [id])
  ayudanteFisicoId      String?
  ayudanteFisico        Igualador?      @relation("AyudanteFisicoOrders", fields: [ayudanteFisicoId], references: [id])
  vendedorId            String?
  vendedor              Vendedor?       @relation("VendedorFisicoOrders", fields: [vendedorId], references: [id])
  colorGroupId          String
  colorGroup            ColorGroup      @relation(fields: [colorGroupId], references: [id])
  igualacionLineId      String?
  igualacionLine        IgualacionLine? @relation(fields: [igualacionLineId], references: [id])
  colorName             String
  liters                Float
  source                OrderSource     @default(MOSTRADOR)
  status                OrderStatus     @default(PENDIENTE)
  queuePosition         Int
  notes                 String?
  locationId            String?
  location              Location?       @relation(fields: [locationId], references: [id])
  productionTimeMinutes Int?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  startedAt             DateTime?
  completedAt           DateTime?
  deliveredAt           DateTime?
  cancelledAt           DateTime?
  pausedAt              DateTime?
  labels                Label[]

  @@index([status])
  @@index([folio])
  @@index([clientId])
  @@index([queuePosition])
  @@index([ayudanteId])
  @@index([operadorFisicoId])
}

model Label {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  content   Json
  printedAt DateTime @default(now())

  @@index([orderId])
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  action    AuditAction
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  changes   Json?
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}
