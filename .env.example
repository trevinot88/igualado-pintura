# ─── Base de datos (PostgreSQL) ──────────────────────────────
# URL de conexión usada por la app en runtime (puede ir vía pooler)
DATABASE_URL=
# Conexión directa usada por Prisma para migraciones (sin pooler)
DIRECT_URL=

# ─── Autenticación (NextAuth v5) ─────────────────────────────
# Secreto para firmar los JWT. Generar con: openssl rand -base64 32
AUTH_SECRET=
# URL pública de la app (ej. https://igualado-pintura.onrender.com)
NEXTAUTH_URL=

# ─── Entorno ─────────────────────────────────────────────────
# "development" | "production"
NODE_ENV=development
# "true" activa datos de demostración (IGNORADO en producción)
DEMO_MODE=false

# ─── WhatsApp (Green API) ────────────────────────────────────
# Notificación automática al cliente cuando el pedido queda LISTO
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=
# Remitente, ej. "DYRLO <noreply@dyrlo.com>"
EMAIL_FROM=

# ─── Impresión de etiquetas (opcional) ───────────────────────
# Endpoint de la impresora térmica de red (ZPL). Pendiente de implementar.
PRINTER_URL=
